SECRET_KEY=
DEBUG=False
ALLOWED_HOSTS=erp.pollyanasdolce.com,localhost

# Opcion A: una sola URL operativa
DATABASE_URL=postgresql://usuario:password@host:5432/nombre_db

# Opcion B: si DATABASE_URL apunta a Railway interno (*.railway.internal),
# define tambien la URL publica para trabajo local fuera de Railway.
# DATABASE_PUBLIC_URL=postgresql://usuario:password@shinkansen.proxy.rlwy.net:29018/nombre_db?sslmode=require

# Opcion C: Postgres local por variables separadas
# DB_NAME=pastelerias_erp
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=127.0.0.1
# DB_PORT=5432

REDIS_URL=redis://localhost:6379/0
STATIC_ROOT=/app/staticfiles
OPENAI_API_KEY=
