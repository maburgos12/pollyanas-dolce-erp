SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
TIME_ZONE=America/Mazatlan

# Local Docker/Postgres settings (used when DATABASE_URL is not set)
DB_NAME=pastelerias_erp
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# Production (Railway) - set this in Railway variables
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Security / CORS (production)
CORS_ALLOW_ALL_ORIGINS=False
# CORS_ALLOWED_ORIGINS=https://tu-app.railway.app
# CSRF_TRUSTED_ORIGINS=https://tu-app.railway.app
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000

# Optional bootstrap superuser at startup
CREATE_SUPERUSER=0
# DJANGO_SUPERUSER_USERNAME=admin
# DJANGO_SUPERUSER_EMAIL=admin@tuempresa.com
# DJANGO_SUPERUSER_PASSWORD=change-me

# Gunicorn workers
WEB_CONCURRENCY=2

# Google Drive sync (Inventario)
# Folder id raíz que contiene carpetas por mes (ej: "ALMACEN ENERO 2026")
# GOOGLE_DRIVE_ROOT_FOLDER_ID=
# Credenciales de service account (elige una opción)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GOOGLE_SERVICE_ACCOUNT_B64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50IiwiLi4u
# GOOGLE_SERVICE_ACCOUNT_FILE=/app/secrets/google-service-account.json

# Auto sync scheduler (optional, runs inside app container)
ENABLE_AUTO_SYNC_ALMACEN=0
AUTO_SYNC_INTERVAL_HOURS=24

# Auto maintenance scheduler (Integraciones API, optional)
ENABLE_AUTO_MAINT_INTEGRACIONES=0
AUTO_MAINT_INTEGRACIONES_INTERVAL_HOURS=24
AUTO_MAINT_INTEGRACIONES_IDLE_DAYS=30
AUTO_MAINT_INTEGRACIONES_IDLE_LIMIT=100
AUTO_MAINT_INTEGRACIONES_RETAIN_DAYS=90
AUTO_MAINT_INTEGRACIONES_MAX_DELETE=5000
# 1 = preview only, 0 = live execution (requires confirm)
AUTO_MAINT_INTEGRACIONES_DRY_RUN=1
# AUTO_MAINT_INTEGRACIONES_CONFIRM_LIVE=YES
# AUTO_MAINT_INTEGRACIONES_ACTOR_USERNAME=admin

# Point browser bridge (POS Point sin API)
POINT_BASE_URL=https://point.example.com
POINT_USERNAME=readonly.user
POINT_PASSWORD=change-me
POINT_HEADLESS=1
POINT_TIMEOUT=30000
POINT_BROWSER_SLOW_MO=0
POINT_SYNC_INTERVAL_HOURS=24
POINT_RETRY_ATTEMPTS=3
POINT_SYNC_MAX_BRANCHES=8
POINT_SYNC_MAX_PAGES_PER_BRANCH=50
POINT_SALES_EXCLUDED_BRANCHES=CEDIS,ALMACEN,PRODUCCION CRUCERO,DEVOLUCIONES
POINT_BRIDGE_STORAGE_ROOT=/app/storage/pos_bridge
ENABLE_AUTO_SYNC_POS_BRIDGE=0
AUTO_SYNC_POS_BRIDGE_INTERVAL_HOURS=24
AUTO_SYNC_POS_BRIDGE_INITIAL_DELAY_SECONDS=60
AUTO_SYNC_POS_BRIDGE_INCLUDE_INVENTORY=1
AUTO_SYNC_POS_BRIDGE_INCLUDE_SALES=0
AUTO_SYNC_POS_BRIDGE_SALES_LOOKBACK_DAYS=3
AUTO_SYNC_POS_BRIDGE_SALES_LAG_DAYS=1
POS_BRIDGE_SALES_CLOSE_HOUR=1
POS_BRIDGE_SALES_CLOSE_MINUTE=30
POS_BRIDGE_SALES_CLOSE_LOOKBACK_DAYS=3
POS_BRIDGE_SALES_CLOSE_LAG_DAYS=1
POS_BRIDGE_INVENTORY_HOUR=2
POS_BRIDGE_INVENTORY_MINUTE=15
PICKUP_AVAILABILITY_FRESHNESS_MINUTES=20
PICKUP_STOCK_BUFFER_DEFAULT=1
PICKUP_LOW_STOCK_THRESHOLD=3
PICKUP_RESERVATION_TTL_MINUTES=15
# Override opcional en JSON para calibrar selectores sin tocar código.
# POINT_SELECTOR_OVERRIDES_JSON={"inventory.branch_select":"select[name='branch']"}
